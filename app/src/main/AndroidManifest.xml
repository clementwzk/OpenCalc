<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android" >

    <!-- Permission required for haptic feedback on button presses -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Permission required for overlay windows (e.g., floating calculator) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- Permission required to display calculator on lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Application Configuration -->
    <application
        android:name=".OpenCalcApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_display"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true" <!-- Enables right-to-left language support -->
        android:theme="@style/AppTheme">

        <!-- Settings screen for app configuration -->
        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false"
            android:label="@string/title_activity_settings" />
        
        <!-- About screen displaying app information and credits -->
        <activity
            android:name=".activities.AboutActivity"
            android:exported="false" />
        
        <!-- Main calculator activity - app entry point -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true" <!-- Allows launching from other apps -->
            android:windowSoftInputMode="stateAlwaysHidden" <!-- Prevents keyboard from auto-showing -->
            android:showOnLockScreen="true" <!-- Enables usage on lock screen -->
            android:turnScreenOn="true"> <!-- Wakes screen when launched -->
            
            <!-- Launcher intent filter - makes this the app's main entry point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Quick Settings Tile Service - provides quick access to calculator from notification panel -->
        <service
            android:name=".services.MyTileService"
            android:label="@string/app_name_display"
            android:icon="@drawable/ic_launcher_foreground_tile"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE" <!-- Required for QS tile -->
            android:exported="true"> <!-- Must be exported for system to bind -->
            
            <!-- Intent filter to register this service as a Quick Settings tile -->
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

</application>
</manifest>